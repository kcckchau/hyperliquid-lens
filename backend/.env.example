DATABASE_URL=postgres://hyperliquid:hyperliquid@localhost:5433/hyperliquid_lens
RUST_LOG=info

# Telegram alerts — both required to enable. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PORT=3001
# Comma-separated list of coins to subscribe to
COINS=BTC,ETH,SOL

# Chart warm-up tuning. These defaults target stable 50/100/200 EMA rendering
# and a TradingView-style hidden pre-roll on first load.
CHART_DEFAULT_VISIBLE_BARS=300
CHART_MAX_REMOTE_BARS=5000
CHART_EMA_PERIODS=50,100,200
CHART_SMA_PERIODS=
CHART_ROLLING_VOLUME_PERIODS=20
CHART_MARKET_STRUCTURE_LOOKBACKS=20,50
CHART_ORB_WINDOW_BARS=
CHART_ENABLE_VWAP=false
CHART_MULTI_SYMBOL_CONTEXT_BARS=
CHART_WARMUP_1M_BARS=2000
CHART_WARMUP_5M_BARS=1500
CHART_WARMUP_15M_BARS=1000
CHART_WARMUP_1H_BARS=1000
CHART_WARMUP_4H_BARS=500
CHART_WARMUP_1D_BARS=500
